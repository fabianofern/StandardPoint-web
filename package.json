{
  "name": "standardpoint-web",
  "version": "1.0.0",
  "description": "Ferramenta de Análise de Pontos de Função",
  "main": "public/electron.js",
  "scripts": {
    "dev:web": "vite --port 3002",
    "dev:server": "nodemon --exec tsx src/server/index.ts",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:web\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run dev",
    "test": "vitest"
  },
  "keywords": [
    "ifpug",
    "function-point",
    "electron",
    "standardpoint"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jwks-rsa": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "jsdom": "^29.1.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.8",
    "vitest": "^2.1.9"
  }
}
